ENTRY(_start) /* Наша точка входа из kernel.rs */

SECTIONS
{
    /* Начинаем загрузку ядра с 1 МиБ */
    . = 1M;

    .text :
    {
        /* Сначала кладем сам код */
        *(.text .text.*)
    }

    .rodata :
    {
        /* Затем только чтение (строки и константы) */
        *(.rodata .rodata.*)
    }

    .data :
    {
        /* Данные */
        *(.data .data.*)
    }

    .bss :
    {
        /* Обнуленные переменные */
        *(.bss .bss.*)
    }
}
